{
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "framework": "vite",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/assets/:path*",
      "destination": "/client/assets/:path*"
    },
    {
      "source": "/client/:path*",
      "destination": "/client/:path*"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/ssr"
    },
    {
      "source": "/:path*",
      "destination": "/api/ssr"
    }
  ],
  "headers": [
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "cache-control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "functions": {
    "api/ssr.ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
